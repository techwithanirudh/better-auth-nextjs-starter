{
  "name": "better-auth-nextjs-starter",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "typegen": "next typegen",
    "postbuild": "next-sitemap --config next-sitemap.config.ts",
    "analyze": "cross-env ANALYZE=true next build",
    "start": "next start",
    "check": "ultracite check",
    "check:unsafe": "ultracite check --unsafe",
    "check:write": "ultracite check",
    "typecheck": "tsc --noEmit --incremental false",
    "check:spelling": "cspell -c .cspell.json --no-progress --no-summary --no-must-find-files --unique",
    "auth:generate": "bunx @better-auth/cli generate --config src/server/auth/index.ts --output src/server/db/schema/auth.ts --yes && bun format src/server/db/schema/auth.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@bprogress/core": "^1.3.4",
    "@bprogress/next": "^3.2.12",
    "@cspell/dict-bash": "^4.2.2",
    "@cspell/dict-npm": "^5.2.36",
    "@icons-pack/react-simple-icons": "^13.12.0",
    "@neondatabase/serverless": "^1.0.2",
    "@next/bundle-analyzer": "16.1.6",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-use-controllable-state": "^1.2.2",
    "@t3-oss/env-core": "^0.13.10",
    "@t3-oss/env-nextjs": "^0.13.10",
    "better-auth": "^1.5.4",
    "better-auth-ui": "npm:@daveyplate/better-auth-ui",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cspell": "^9.7.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "embla-carousel-react": "^8.6.0",
    "harden-react-markdown": "^1.1.8",
    "jiti": "^2.6.1",
    "katex": "^0.16.35",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-sitemap": "^4.2.3",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-safe-area": "^1.3.0",
    "use-stick-to-bottom": "^1.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@biomejs/biome": "2.4.5",
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "cross-env": "^10.1.0",
    "drizzle-kit": "^0.31.9",
    "lefthook": "^2.1.2",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "ultracite": "7.2.5"
  },
  "trustedDependencies": [
    "@tailwindcss/oxide",
    "core-js",
    "lefthook"
  ],
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}